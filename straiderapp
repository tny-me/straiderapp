const fmtD=ds=>{const d=new Date(ds+'T12:00');return `${DAYS[d.getDay()]} ${d.getDate()} ${MONTHS[d.getMonth()]}`;};
function cStr(h){let s=0;const d=new Date();while(true){const k=d.toISOString().split('T')[0];if(h.logs.includes(k)){s++;d.setDate(d.getDate()-1);}else break;}return s;}
