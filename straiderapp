let runInt=null,runStart=null,runElapsed=0,runRunning=false,kmCI=null;

function toggleRun(){
  if(!runRunning){
    runRunning=true;runStart=Date.now()-runElapsed*1000;runInt=setInterval(tickRun,1000);
    startGPS();
    document.getElementById('run-btn-txt').textContent='Pausar';
    document.getElementById('run-btn-icon').innerHTML='<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>';
    document.getElementById('run-btn-icon').setAttribute('fill','currentColor');
    document.getElementById('run-btn-icon').setAttribute('stroke','none');
    document.getElementById('run-stop').style.display='flex';
    document.getElementById('run-timer').classList.add('on');
    document.getElementById('run-kicker').textContent='Corriendo ahora';
  } else {
    runRunning=false;clearInterval(runInt);
    document.getElementById('run-btn-txt').textContent='Reanudar';
    document.getElementById('run-btn-icon').innerHTML='<polygon points="5 3 19 12 5 21 5 3"/>';
    document.getElementById('run-timer').classList.remove('on');
    document.getElementById('run-kicker').textContent='En pausa';
  }
}

function tickRun(){
  runElapsed=Math.floor((Date.now()-runStart)/1000);
  document.getElementById('run-timer').textContent=fmtT(runElapsed);
  // If GPS not ready, fallback estimate
  if(!gpsReady&&runElapsed>0){
    const km=+(runElapsed/60/6).toFixed(2);
    document.getElementById('rn-km').textContent=km;
    document.getElementById('rn-cal').textContent=Math.floor(km*70);
    if(km>0){const pm=Math.floor(runElapsed/60/km);const ps=Math.round(((runElapsed/60/km)-pm)*60);document.getElementById('rn-pace').textContent=`${pm}:${pad(ps)}`;}
  }
}

function stopRun(){
  runRunning=false;clearInterval(runInt);stopGPS();
  // Use GPS km if available, else fallback
  const kmGPS=calcTotalKm();
  const km=kmGPS>0?+kmGPS.toFixed(2):+(runElapsed/60/6).toFixed(2);
  if(runElapsed>30){
    D.run.sessions.push({date:today(),dur:runElapsed,km});
    if(D.run.sessions.length>30)D.run.sessions.shift();
    D.run.streak++;if(D.run.streak>D.run.bestStreak)D.run.bestStreak=D.run.streak;persist(D);
  }
  gpsPositions=[];runElapsed=0;runStart=null;
  document.getElementById('run-timer').textContent='00:00:00';
  document.getElementById('run-timer').classList.remove('on');
  document.getElementById('run-btn-txt').textContent='Iniciar';
  document.getElementById('run-btn-icon').innerHTML='<polygon points="5 3 19 12 5 21 5 3"/>';
  document.getElementById('run-stop').style.display='none';
  document.getElementById('rn-km').textContent='0.00';
  document.getElementById('rn-km').classList.remove('live');
  document.getElementById('rn-cal').textContent='0';
  document.getElementById('rn-pace').textContent='--:--';
  document.getElementById('run-kicker').textContent='Listo para correr';
  renderRun();
}

function renderRun(){
  const g=greet().split('\n');document.getElementById('run-h1').innerHTML=g[0]+'<br>'+g[1];
  renderKmChart();renderTimeBars();renderRunStreak();renderBadges();
}

function renderKmChart(){
