// ════════════════════════════════════════
let gpsWatchId=null;
let gpsPositions=[];
let gpsAccuracy=null;
let gpsReady=false;

function gpsDistanceM(lat1,lon1,lat2,lon2){
  const R=6371000;
  const dLat=(lat2-lat1)*Math.PI/180;
  const dLon=(lon2-lon1)*Math.PI/180;
  const a=Math.sin(dLat/2)*Math.sin(dLat/2)+Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)*Math.sin(dLon/2);
  return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
}

function calcTotalKm(){
  if(gpsPositions.length<2)return 0;
  let total=0;
  for(let i=1;i<gpsPositions.length;i++){
    const p=gpsPositions[i-1],q=gpsPositions[i];
    const d=gpsDistanceM(p.lat,p.lon,q.lat,q.lon);
    if(d<50)total+=d; // filter GPS jumps
  }
  return total/1000;
}

function startGPS(){
  if(!navigator.geolocation){
    document.getElementById('gps-lbl').textContent='GPS no soportado';return;
  }
  document.getElementById('gps-dot').className='gps-dot searching';
  document.getElementById('gps-lbl').textContent='Buscando señal...';
  gpsPositions=[];
  gpsWatchId=navigator.geolocation.watchPosition(
    pos=>{
      const{latitude:lat,longitude:lon,accuracy}=pos.coords;
      gpsAccuracy=Math.round(accuracy);
      gpsReady=true;
      document.getElementById('gps-dot').className='gps-dot locked';
      document.getElementById('gps-lbl').textContent='GPS activo';
      document.getElementById('gps-acc').textContent=`±${gpsAccuracy}m`;
      if(runRunning){
        gpsPositions.push({lat,lon,t:Date.now()});
        const km=calcTotalKm();
        document.getElementById('rn-km').textContent=km.toFixed(2);
        document.getElementById('rn-km').classList.add('live');
        // pace
        if(km>0.05&&runElapsed>0){
          const paceSec=runElapsed/km;
          const pm=Math.floor(paceSec/60);const ps=Math.round(paceSec%60);
          document.getElementById('rn-pace').textContent=`${pm}:${pad(ps)}`;
        }
        // calories (MET 8 running ~8 kcal/min adjusted)
        document.getElementById('rn-cal').textContent=Math.floor(km*70);
      }
    },
    err=>{
      document.getElementById('gps-dot').className='gps-dot';
      document.getElementById('gps-lbl').textContent=err.code===1?'Permiso denegado':'Sin señal GPS';
      document.getElementById('gps-acc').textContent='';
      gpsReady=false;
    },
    {enableHighAccuracy:true,maximumAge:2000,timeout:10000}
  );
}

function stopGPS(){
  if(gpsWatchId!==null){navigator.geolocation.clearWatch(gpsWatchId);gpsWatchId=null;}
  document.getElementById('gps-dot').className='gps-dot';
  document.getElementById('gps-lbl').textContent='GPS no activo';
  document.getElementById('gps-acc').textContent='';
  gpsReady=false;
}

