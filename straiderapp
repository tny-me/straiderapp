<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="VIDA">
<title>VIDA</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,300;0,400;0,600;0,700;0,800;0,900;1,700;1,900&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#e8e5e0;
  --card:#f5f3ef;
  --card2:#ede9e3;
  --border:#d8d4cc;
  --border2:#c8c4bc;
  --t1:#1a1918;
  --t2:#6b6860;
  --t3:#a8a49c;
  --dk:#111110;
  --dk2:#1a1918;
  --dk3:#242320;
  --dk-b:#2e2c28;
  --dk-t1:#f0ede8;
  --dk-t2:#888580;
  --dk-t3:#555250;
  --navy:#0f1f3d;
  --navy2:#162a50;
  --navy-b:#263f6e;
  --navy-t1:#e8eef8;
  --navy-t3:#4a5f88;
  --streak:#7eb3ff;
  --green:#1a7a3c;
  --green-bg:#e4f5eb;
  --green-dot:#2d9e52;
  --red:#c0392b;
  --red-bg:#fdecea;
  --orange:#c25a15;
  --orange-bg:#fdf0e6;
  --blue:#1e4fa0;
}
html,body{height:100%;background:var(--bg);overflow:hidden;-webkit-font-smoothing:antialiased}
body{font-family:'Barlow',sans-serif;color:var(--t1)}
.app{max-width:430px;margin:0 auto;height:100dvh;display:flex;flex-direction:column;background:var(--bg);overflow:hidden}
.screens{flex:1;overflow:hidden;position:relative}
.screen{position:absolute;inset:0;overflow-y:auto;display:none;padding:env(safe-area-inset-top,0) 0 76px}
.screen.active{display:block;animation:fadeUp .22s cubic-bezier(.16,1,.3,1) both}
.screen::-webkit-scrollbar{display:none}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
@keyframes slideDown{from{opacity:0;transform:translateY(-12px)}to{opacity:1;transform:translateY(0)}}

/* NAV */
.nav{display:flex;justify-content:space-around;align-items:center;padding:10px 0 max(18px,env(safe-area-inset-bottom));background:var(--dk);border-top:1px solid var(--dk-b);flex-shrink:0}
.nb{display:flex;flex-direction:column;align-items:center;gap:4px;background:none;border:none;color:var(--dk-t3);cursor:pointer;font-family:'Barlow Condensed',sans-serif;font-size:9px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;padding:4px 12px;transition:color .2s}
.nb.active{color:var(--dk-t1)}
.nb svg{width:21px;height:21px;stroke:currentColor;fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round}
.nb-dot{width:3px;height:3px;border-radius:50%;background:var(--dk-t1);opacity:0;margin-top:1px;transition:opacity .2s}
.nb.active .nb-dot{opacity:1}

/* HEADERS */
.page-header{padding:32px 20px 18px}
.page-kicker{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--t3);margin-bottom:5px}
.page-h1{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-style:italic;font-size:50px;letter-spacing:-.01em;line-height:.95;text-transform:uppercase;color:var(--t1)}
.sl{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--t3)}
.sdiv{padding:20px 20px 10px}

/* CARDS */
.lcard{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:18px 20px}
.dcard{background:var(--dk);border:1px solid var(--dk-b);border-radius:18px;padding:18px 20px;position:relative;overflow:hidden}
.dcard::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.025),transparent 60%);pointer-events:none;border-radius:18px}
.ncard{background:var(--navy);border:1px solid var(--navy-b);border-radius:18px;padding:18px 20px;position:relative;overflow:hidden}
.ncard::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 80% 20%,rgba(126,179,255,.08),transparent 60%);pointer-events:none}

/* ══ MUSIC CHIP ══ */
.music-chip{background:var(--dk);border:1px solid var(--dk-b);border-radius:16px;padding:12px 14px;margin:0 16px 0;display:flex;align-items:center;gap:12px;animation:slideDown .3s cubic-bezier(.16,1,.3,1);position:relative;overflow:hidden}
.music-chip::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,rgba(255,255,255,.015),transparent);pointer-events:none}
.music-art{width:44px;height:44px;border-radius:10px;background:var(--dk3);flex-shrink:0;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative}
.music-art img{width:100%;height:100%;object-fit:cover;border-radius:10px}
.music-art-icon{width:20px;height:20px;stroke:var(--dk-t3);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.music-art-playing{position:absolute;bottom:3px;right:3px;display:flex;gap:1.5px;align-items:flex-end}
.music-art-playing span{width:2.5px;background:var(--dk-t1);border-radius:1px;animation:eq .8s ease-in-out infinite alternate}
.music-art-playing span:nth-child(1){height:6px;animation-delay:0s}
.music-art-playing span:nth-child(2){height:10px;animation-delay:.2s}
.music-art-playing span:nth-child(3){height:7px;animation-delay:.4s}
@keyframes eq{from{transform:scaleY(.4)}to{transform:scaleY(1)}}
.music-info{flex:1;min-width:0}
.music-title{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:14px;letter-spacing:.02em;color:var(--dk-t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.music-artist{font-size:12px;color:var(--dk-t3);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.music-source{display:flex;align-items:center;gap:4px;margin-top:4px}
.music-source-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.music-source-lbl{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--dk-t3)}
.music-controls{display:flex;align-items:center;gap:2px;flex-shrink:0}
.mc-btn{width:36px;height:36px;border-radius:50%;background:none;border:none;color:var(--dk-t2);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;-webkit-tap-highlight-color:transparent}
.mc-btn:active{background:var(--dk2);transform:scale(.9)}
.mc-btn svg{width:17px;height:17px;fill:currentColor;stroke:none}
.mc-btn.play svg{width:19px;height:19px}
.music-chip-off{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:12px 16px;margin:0 16px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:border-color .2s}
.music-chip-off:active{background:var(--card2)}

/* RUN TIMER */
.run-timer-display{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-style:italic;font-size:72px;letter-spacing:-.03em;line-height:1;color:var(--dk-t1);transition:color .3s;padding:18px 0 14px}
.run-timer-display.on{color:var(--streak)}
.run-metrics{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px;background:var(--dk-b);border-radius:12px;overflow:hidden;margin-bottom:18px}
.rm{background:var(--dk2);padding:12px 10px;text-align:center}
.rm-val{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:23px;color:var(--dk-t1);letter-spacing:-.01em;transition:color .2s}
.rm-val.live{color:var(--streak)}
.rm-lbl{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:9px;letter-spacing:.16em;text-transform:uppercase;color:var(--dk-t3);margin-top:2px}
/* GPS indicator */
.gps-row{display:flex;align-items:center;gap:6px;margin-bottom:14px}
.gps-dot{width:7px;height:7px;border-radius:50%;background:var(--dk-t3);flex-shrink:0;transition:background .3s}
.gps-dot.locked{background:#4ade80;animation:pulse 1.5s ease-in-out infinite}
.gps-dot.searching{background:#fb923c;animation:pulse .8s ease-in-out infinite}
.gps-lbl{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--dk-t3);transition:color .3s}
.gps-acc{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:10px;color:var(--dk-t3);margin-left:auto}

/* RUN BUTTONS */
.btn-run-start{flex:1;height:50px;border-radius:50px;background:var(--dk-t1);color:var(--dk);font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:15px;letter-spacing:.15em;text-transform:uppercase;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .15s}
.btn-run-start:active{opacity:.85;transform:scale(.97)}
.btn-run-stop{width:50px;height:50px;border-radius:50%;background:transparent;color:#ff6b6b;border:1.5px solid #ff6b6b44;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0}
.btn-run-stop:active{background:#ff3b3018}

/* CHARTS */
.chart-lcard{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:16px 14px 12px;margin:0 16px}

/* STREAK */
.streak-num-big{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-style:italic;font-size:68px;letter-spacing:-.03em;line-height:1;color:var(--streak)}
.sg{display:grid;grid-template-columns:repeat(7,1fr);gap:5px;margin-top:14px}
.sd{aspect-ratio:1;border-radius:6px;background:var(--navy2);display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:600;color:var(--navy-t3);transition:all .2s}
.sd.done{background:rgba(126,179,255,.18);color:var(--streak);border:1px solid rgba(126,179,255,.35)}
.sd.today{border:1px solid #4a5f88}
.sd.done.today{border-color:var(--streak)}

/* BADGES */
.badge-row{display:flex;gap:8px;flex-wrap:wrap;padding:0 16px}
.badge{display:inline-flex;align-items:center;gap:5px;background:var(--card);border:1px solid var(--border);border-radius:50px;padding:6px 12px;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:var(--t2)}
.badge svg{width:12px;height:12px;stroke:var(--t3);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.badge.earned{border-color:var(--border2);color:var(--t1)}
.badge.earned svg{stroke:var(--t1)}

/* HABITS */
.habit-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px 18px;margin:0 16px 9px;display:flex;align-items:center;gap:12px;position:relative;overflow:hidden;transition:border-color .2s}
.habit-card::after{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--border2);border-radius:0 2px 2px 0;transition:background .2s}
.habit-card.done-today::after{background:var(--green-dot)}
.hibx{width:40px;height:40px;border-radius:11px;background:var(--card2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s}
.hibx svg{width:19px;height:19px;stroke:var(--t3);fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round;transition:stroke .2s}
.habit-card.done-today .hibx{background:var(--green-bg);border-color:#b8e0c8}
.habit-card.done-today .hibx svg{stroke:var(--green)}
.hname{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:17px;letter-spacing:.04em;text-transform:uppercase;color:var(--t1)}
.hsub{font-size:12px;color:var(--t3);margin-top:2px}
.hsub span{color:var(--t1);font-weight:500}
.hcheck{width:27px;height:27px;border-radius:50%;border:1.5px solid var(--border2);background:none;cursor:pointer;flex-shrink:0;margin-left:auto;display:flex;align-items:center;justify-content:center;transition:all .2s}
.hcheck svg{width:12px;height:12px;stroke:#fff;fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round;opacity:0;transition:opacity .15s}
.hcheck.on{background:var(--green-dot);border-color:var(--green-dot)}.hcheck.on svg{opacity:1}

/* CAL DARK */
.cal-wrap{background:var(--dk);border:1px solid var(--dk-b);border-radius:18px;padding:18px;margin:0 16px}
.cal-month{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:15px;letter-spacing:.1em;text-transform:uppercase;color:var(--dk-t1)}
.cal-nav{background:none;border:none;color:var(--dk-t3);font-size:20px;cursor:pointer;padding:4px 10px;transition:color .15s}
.cal-nav:hover{color:var(--dk-t1)}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
.cd{aspect-ratio:1;border-radius:6px;background:var(--dk2);display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:600;color:var(--dk-t3);transition:all .2s}
.cd.done{background:rgba(46,158,82,.18);color:#4ade80;border:1px solid rgba(46,158,82,.3)}
.cd.today{outline:1px solid var(--dk-t2)}
.cd.done.today{outline-color:#4ade80}
.hab-filter-row{display:flex;gap:8px;flex-wrap:wrap;padding:0 16px;margin-bottom:12px}
.hab-pill{display:inline-flex;align-items:center;gap:6px;padding:7px 13px;border-radius:50px;border:1px solid var(--border2);background:var(--card);color:var(--t2);font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:11px;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;transition:all .2s}
.hab-pill.active{background:var(--t1);border-color:var(--t1);color:var(--card)}
.hab-pill svg{width:11px;height:11px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}

/* HEALTH */
.weight-big{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-style:italic;font-size:84px;letter-spacing:-.04em;line-height:.9;color:var(--dk-t1)}
.weight-unit{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:22px;color:var(--dk-t2);margin-left:3px;vertical-align:super}
.weight-trend{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px;margin-top:8px}
.td{color:#4ade80}.tu{color:#ff6b6b}.ts{color:var(--dk-t3)}
.prog-track{height:3px;background:var(--dk3);border-radius:2px;margin-top:14px;overflow:hidden}
.prog-fill{height:100%;border-radius:2px;background:var(--streak);transition:width .8s cubic-bezier(.16,1,.3,1)}
.input-row{display:flex;gap:9px;align-items:center;padding:0 16px}
.ni{flex:1;background:var(--card);border:1px solid var(--border2);border-radius:12px;color:var(--t1);font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:20px;letter-spacing:.03em;padding:13px 16px;outline:none;-webkit-appearance:none;transition:border-color .2s}
.ni:focus{border-color:var(--t2)}.ni::placeholder{color:var(--t3)}
.btn-save{background:var(--t1);color:var(--card);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:13px;letter-spacing:.15em;text-transform:uppercase;border:none;border-radius:12px;padding:13px 18px;cursor:pointer;white-space:nowrap;transition:all .15s}
.btn-save:active{opacity:.8;transform:scale(.97)}
.btn-save-o{background:transparent;color:var(--t1);font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;letter-spacing:.15em;text-transform:uppercase;border:1px solid var(--border2);border-radius:12px;padding:13px 18px;cursor:pointer;white-space:nowrap;transition:all .15s}
.btn-save-o:active{background:var(--card2)}

/* FAST */
.fast-time-big{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-style:italic;font-size:42px;letter-spacing:-.02em;line-height:1;color:var(--t1)}
.fast-sub{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--t3);margin-top:5px}
.fast-pct-lbl{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:20px;color:var(--orange);margin-top:5px}
.fast-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;padding:0 16px;margin-bottom:18px}
.fst{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px 10px;text-align:center}
.fst-n{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:24px;color:var(--t1)}
.fst-l{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--t3);margin-top:3px}
.proto-row{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;padding:0 16px;margin-bottom:18px}
.proto-btn{padding:9px 15px;border-radius:8px;border:1px solid var(--border2);background:var(--card);color:var(--t2);font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;letter-spacing:.08em;cursor:pointer;transition:all .2s}
.proto-btn.on{background:var(--orange-bg);border-color:#e8963a;color:var(--orange)}
.btn-fast-main{display:block;width:calc(100% - 32px);margin:0 16px;height:54px;border-radius:14px;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:17px;letter-spacing:.18em;text-transform:uppercase;border:none;cursor:pointer;transition:all .15s}
.btn-fast-main.start{background:var(--t1);color:var(--card)}
.btn-fast-main.stop{background:var(--red-bg);color:var(--red);border:1.5px solid #e0a8a4}
.btn-fast-main:active{transform:scale(.98);opacity:.9}
.fhi{background:var(--dk);border:1px solid var(--dk-b);border-radius:14px;padding:15px 18px;margin:0 16px 8px;display:flex;align-items:center;justify-content:space-between}
.fhi-date{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:15px;letter-spacing:.04em;text-transform:uppercase;color:var(--dk-t1)}
.fhi-sub{font-size:12px;color:var(--dk-t3);margin-top:2px}
.fhi-st{display:flex;align-items:center;gap:5px;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:12px;letter-spacing:.08em;text-transform:uppercase}
.fhi-st svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round}

/* JOURNAL */
.journal-write{background:var(--dk);border:1px solid var(--dk-b);border-radius:18px;padding:20px;margin:0 16px;position:relative;overflow:hidden}
.j-date-lbl{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--dk-t3);margin-bottom:14px}
textarea.jta{width:100%;background:var(--dk2);border:1px solid var(--dk-b);border-radius:12px;color:var(--dk-t1);font-family:'Barlow',sans-serif;font-size:15px;line-height:1.75;padding:14px 16px;resize:none;outline:none;-webkit-appearance:none;transition:border-color .2s;min-height:120px}
textarea.jta:focus{border-color:var(--dk-t3)}
textarea.jta::placeholder{color:var(--dk-t3)}
.j-bottom{display:flex;justify-content:space-between;align-items:center;margin-top:12px}
.j-wc{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--dk-t3)}
.j-actions{display:flex;gap:8px;align-items:center}
select.mood-sel{background:var(--dk2);border:1px solid var(--dk-b);border-radius:8px;color:var(--dk-t1);font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:13px;letter-spacing:.04em;padding:9px 12px;outline:none;-webkit-appearance:none;cursor:pointer}
.btn-j-save{background:var(--dk-t1);color:var(--dk);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:13px;letter-spacing:.14em;text-transform:uppercase;border:none;border-radius:10px;padding:10px 16px;cursor:pointer;transition:all .15s}
.btn-j-save:active{opacity:.8}
.je-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px 18px;margin:0 16px 9px;cursor:pointer;transition:border-color .2s;position:relative;overflow:hidden}
.je-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--border2)}
.je-card:active{border-color:var(--border2)}
.je-date{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--t3);margin-bottom:5px}
.je-mood{display:inline-block;background:var(--card2);border-radius:4px;padding:2px 8px;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--t2);margin-bottom:7px}
.je-preview{font-size:14px;color:var(--t2);line-height:1.55;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}

/* MODALS */
.ov{position:fixed;inset:0;background:rgba(0,0,0,.45);display:flex;align-items:flex-end;justify-content:center;z-index:200;animation:fadeIn .2s}
.mo{background:var(--card);border:1px solid var(--border);border-radius:22px 22px 0 0;padding:24px 20px max(38px,env(safe-area-inset-bottom));width:100%;max-width:430px;max-height:88dvh;overflow-y:auto}
.mo-handle{width:34px;height:4px;border-radius:2px;background:var(--border2);margin:0 auto 20px}
.mo-title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-style:italic;font-size:28px;text-transform:uppercase;color:var(--t1);margin-bottom:18px}
.mo-dark{background:var(--dk);border:1px solid var(--dk-b);border-radius:22px 22px 0 0;padding:24px 20px max(38px,env(safe-area-inset-bottom));width:100%;max-width:430px;max-height:88dvh;overflow-y:auto}
.ni-text{width:100%;background:var(--card2);border:1px solid var(--border2);border-radius:12px;color:var(--t1);font-family:'Barlow',sans-serif;font-size:16px;padding:14px 16px;outline:none;margin-bottom:14px;-webkit-appearance:none;transition:border-color .2s}
.ni-text:focus{border-color:var(--t2)}.ni-text::placeholder{color:var(--t3)}
.icon-picker{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin-bottom:20px}
.ipbtn{display:flex;flex-direction:column;align-items:center;gap:4px;background:var(--card2);border:1.5px solid transparent;border-radius:12px;padding:10px 6px;cursor:pointer;transition:all .15s}
.ipbtn.sel{border-color:var(--t1);background:var(--card)}
.ipbtn svg{width:19px;height:19px;stroke:var(--t3);fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round}
.ipbtn.sel svg{stroke:var(--t1)}
.ipbtn span{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:9px;letter-spacing:.07em;color:var(--t3);text-transform:uppercase}
.ipbtn.sel span{color:var(--t1)}
.btn-modal-cta{width:100%;height:50px;border-radius:12px;background:var(--t1);color:var(--card);font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:16px;letter-spacing:.18em;text-transform:uppercase;border:none;cursor:pointer;transition:all .15s}
.btn-modal-cta:active{opacity:.85}

/* MISC */
.row{display:flex;align-items:center}.jb{justify-content:space-between}
.gap{gap:10px}.gap2{gap:8px}
.empty-state{text-align:center;padding:32px 20px;font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:13px;letter-spacing:.12em;text-transform:uppercase;color:var(--t3)}
.empty-dk{text-align:center;padding:20px;font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--dk-t3)}
</style>
</head>
<body>
<div class="app">
  <div class="screens">

    <!-- ══════ RUN ══════ -->
    <div class="screen active" id="s-run">
      <div class="page-header">
        <div class="page-kicker" id="run-kicker">Listo para correr</div>
        <div class="page-h1" id="run-h1">Buenos<br>Días</div>
      </div>

      <!-- MUSIC CHIP -->
      <div id="music-area" style="margin-bottom:12px"></div>

      <!-- DARK: run card -->
      <div style="padding:0 16px">
        <div class="dcard">
          <!-- GPS status -->
          <div class="gps-row">
            <div class="gps-dot" id="gps-dot"></div>
            <div class="gps-lbl" id="gps-lbl">GPS no activo</div>
            <div class="gps-acc" id="gps-acc"></div>
          </div>
          <div class="run-timer-display" id="run-timer">00:00:00</div>
          <div class="run-metrics">
            <div class="rm"><div class="rm-val" id="rn-km">0.00</div><div class="rm-lbl">km</div></div>
            <div class="rm"><div class="rm-val" id="rn-pace">--:--</div><div class="rm-lbl">min/km</div></div>
            <div class="rm"><div class="rm-val" id="rn-cal">0</div><div class="rm-lbl">kcal</div></div>
          </div>
          <div style="display:flex;gap:10px">
            <button class="btn-run-start" id="run-btn" style="flex:2" onclick="toggleRun()">
              <svg id="run-btn-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              <span id="run-btn-txt">Iniciar</span>
            </button>
            <button class="btn-run-stop" id="run-stop" style="display:none" onclick="stopRun()">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="#ff6b6b" stroke="none"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
            </button>
          </div>
        </div>
      </div>

      <div class="sdiv"><div class="sl">Tendencia — km recorridos</div></div>
      <div class="chart-lcard">
        <canvas id="km-chart" height="110"></canvas>
        <div id="km-empty" class="empty-state" style="display:none;padding:18px">Sin sesiones aún</div>
      </div>

      <div class="sdiv"><div class="sl">Tiempo por sesión</div></div>
      <div class="chart-lcard" style="padding:14px 12px 10px">
        <div style="display:flex;align-items:flex-end;gap:5px;height:78px;overflow-x:auto" id="run-bars"></div>
      </div>

      <div class="sdiv"><div class="sl">Racha de carrera</div></div>
      <div style="padding:0 16px">
        <div class="ncard">
          <div class="row jb">
            <div>
              <div class="streak-num-big" id="run-streak-n">0</div>
              <div style="font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--navy-t3);margin-top:2px">Días consecutivos</div>
            </div>
            <div style="text-align:right">
              <div style="font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--navy-t3);margin-bottom:4px">Mejor racha</div>
              <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:28px;color:var(--navy-t1)" id="run-best-streak">0</div>
            </div>
          </div>
          <div class="sg" id="run-sgrid"></div>
        </div>
      </div>

      <div class="sdiv"><div class="sl">Logros</div></div>
      <div class="badge-row" id="run-badges"></div>
      <div style="height:24px"></div>
    </div>

    <!-- ══════ HABITS ══════ -->
    <div class="screen" id="s-habits">
      <div class="page-header"><div class="page-kicker">Sistema de hábitos</div><div class="page-h1">Hábitos</div></div>
      <div id="habits-list"></div>
      <div style="padding:0 16px;margin-top:2px">
        <button onclick="openModal('add-modal')" style="width:100%;height:46px;border-radius:12px;background:transparent;color:var(--t3);border:1.5px dashed var(--border2);font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:12px;letter-spacing:.16em;text-transform:uppercase;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Agregar hábito
        </button>
      </div>
      <div class="sdiv"><div class="sl">Calendario</div></div>
      <div class="hab-filter-row" id="hab-filter"></div>
      <div class="cal-wrap">
        <div class="row jb" style="margin-bottom:14px">
          <button class="cal-nav" onclick="chMonth(-1)">‹</button>
          <div class="cal-month" id="cal-label"></div>
          <button class="cal-nav" onclick="chMonth(1)">›</button>
        </div>
        <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px;margin-bottom:6px" id="cal-dow"></div>
        <div class="cal-grid" id="hab-cal" style="gap:4px"></div>
        <div class="row jb" style="margin-top:14px;padding-top:14px;border-top:1px solid var(--dk-b)">
          <div><div style="font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--dk-t3)">Racha actual</div><div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:30px;color:#4ade80;margin-top:2px" id="hab-streak-n">0</div></div>
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
      </div>
      <div style="height:24px"></div>
    </div>

    <!-- ══════ HEALTH ══════ -->
    <div class="screen" id="s-health">
      <div class="page-header"><div class="page-kicker">Tu cuerpo</div><div class="page-h1">Salud</div></div>
      <div style="padding:0 16px">
        <div class="dcard">
          <div style="font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--dk-t3);margin-bottom:8px">Peso actual</div>
          <div><span class="weight-big" id="w-cur">--</span><span class="weight-unit">kg</span></div>
          <div class="weight-trend" id="w-trend"></div>
          <div class="row jb" style="margin-top:14px">
            <div style="font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--dk-t3)">Meta: <span id="w-goal-val" style="color:var(--dk-t1)">--</span> kg</div>
            <div id="w-diff" style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px"></div>
          </div>
          <div class="prog-track"><div class="prog-fill" id="w-prog" style="width:0%"></div></div>
        </div>
      </div>
      <div class="sdiv"><div class="sl">Registrar peso</div></div>
      <div class="input-row"><input type="number" class="ni" id="w-input" placeholder="75.5" step="0.1"><button class="btn-save" onclick="logWeight()">Guardar</button></div>
      <div class="sdiv"><div class="sl">Meta de peso</div></div>
      <div class="input-row"><input type="number" class="ni" id="wg-input" placeholder="70" step="0.5"><button class="btn-save-o" onclick="setWGoal()">Guardar</button></div>
      <div class="sdiv"><div class="sl">Tendencia — historial</div></div>
      <div class="chart-lcard" style="padding:14px 12px 10px"><canvas id="w-chart" height="140"></canvas><div id="w-empty" class="empty-state">Registra tu primer peso</div></div>
      <div style="height:24px"></div>
    </div>

    <!-- ══════ FAST ══════ -->
    <div class="screen" id="s-fast">
      <div class="page-header"><div class="page-kicker">Ayuno intermitente</div><div class="page-h1">Ventana<br>de ayuno</div></div>
      <div style="display:flex;justify-content:center;padding:10px 0 22px">
        <div style="position:relative;width:216px;height:216px">
          <svg width="216" height="216" viewBox="0 0 216 216" style="transform:rotate(-90deg)">
            <circle cx="108" cy="108" r="94" fill="none" stroke="var(--card2)" stroke-width="8"/>
            <circle cx="108" cy="108" r="94" fill="none" stroke="var(--orange)" stroke-width="8" stroke-dasharray="590.6" id="fast-ring" stroke-dashoffset="590.6" stroke-linecap="round" style="transition:stroke-dashoffset .8s cubic-bezier(.16,1,.3,1)"/>
          </svg>
          <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center">
            <div class="fast-time-big" id="fast-timer">00:00</div>
            <div class="fast-sub" id="fast-sub">en ayuno</div>
            <div class="fast-pct-lbl" id="fast-pct">0%</div>
          </div>
        </div>
      </div>
      <div class="fast-stats">
        <div class="fst"><div class="fst-n" id="fast-goal-v">16</div><div class="fst-l">meta hrs</div></div>
        <div class="fst"><div class="fst-n" id="fast-el-v">0.0</div><div class="fst-l">hrs ayuno</div></div>
        <div class="fst"><div class="fst-n" id="fast-stk-v">0</div><div class="fst-l">racha</div></div>
      </div>
      <div style="padding:0 20px 10px"><div class="sl">Protocolo</div></div>
      <div class="proto-row">
        <button id="fg-12" class="proto-btn" onclick="setFG(12)">12:12</button>
        <button id="fg-14" class="proto-btn" onclick="setFG(14)">14:10</button>
        <button id="fg-16" class="proto-btn" onclick="setFG(16)">16:8</button>
        <button id="fg-18" class="proto-btn" onclick="setFG(18)">18:6</button>
        <button id="fg-20" class="proto-btn" onclick="setFG(20)">20:4</button>
      </div>
      <button class="btn-fast-main start" id="fast-btn" onclick="toggleFast()">Iniciar ayuno</button>
      <div style="text-align:center;font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--t3);margin-top:10px" id="fast-start-lbl"></div>
      <div class="sdiv"><div class="sl">Historial</div></div>
      <div id="fast-hist"></div>
      <div style="height:24px"></div>
    </div>

    <!-- ══════ JOURNAL ══════ -->
    <div class="screen" id="s-journal">
      <div class="page-header"><div class="page-kicker">Reflexión diaria</div><div class="page-h1">Diario</div></div>
      <div class="journal-write">
        <div class="j-date-lbl" id="j-today-lbl"></div>
        <textarea class="jta" id="j-input" rows="5" placeholder="¿Qué tienes en mente hoy?&#10;&#10;Reflexiona. Escribe sin filtros."></textarea>
        <div class="j-bottom">
          <div class="j-wc" id="j-wc">0 palabras</div>
          <div class="j-actions">
            <select class="mood-sel" id="j-mood"><option value="">Estado</option><option value="En flujo">En flujo</option><option value="Tranquilo">Tranquilo</option><option value="Reflexivo">Reflexivo</option><option value="Inquieto">Inquieto</option><option value="Difícil">Difícil</option></select>
            <button class="btn-j-save" onclick="saveJournal()">Guardar</button>
          </div>
        </div>
      </div>
      <div class="sdiv"><div class="sl">Entradas anteriores</div></div>
      <div id="j-entries"></div>
      <div style="height:24px"></div>
    </div>

  </div>

  <nav class="nav">
    <button class="nb active" id="nb-run" onclick="goTo('run')"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="2"/><path d="M5 20l2-5 3 2 2-4 4 7"/><path d="M16 6l-2 4-3-1-2 3"/></svg><span>Correr</span><div class="nb-dot"></div></button>
    <button class="nb" id="nb-habits" onclick="goTo('habits')"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg><span>Hábitos</span><div class="nb-dot"></div></button>
    <button class="nb" id="nb-health" onclick="goTo('health')"><svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg><span>Salud</span><div class="nb-dot"></div></button>
    <button class="nb" id="nb-fast" onclick="goTo('fast')"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 15"/></svg><span>Ayuno</span><div class="nb-dot"></div></button>
    <button class="nb" id="nb-journal" onclick="goTo('journal')"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg><span>Diario</span><div class="nb-dot"></div></button>
  </nav>
</div>

<!-- ADD HABIT MODAL -->
<div class="ov" id="add-modal" style="display:none" onclick="if(event.target===this)closeModal('add-modal')">
  <div class="mo"><div class="mo-handle"></div><div class="mo-title">Nuevo hábito</div>
    <input type="text" class="ni-text" id="h-name" placeholder="Nombre del hábito...">
    <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--t3);margin-bottom:10px">Icono</div>
    <div class="icon-picker" id="h-icons"></div>
    <button class="btn-modal-cta" onclick="addHabit()">Agregar hábito</button>
  </div>
</div>

<!-- JOURNAL VIEW MODAL -->
<div class="ov" id="j-modal" style="display:none" onclick="if(event.target===this)closeModal('j-modal')">
  <div class="mo-dark"><div style="width:34px;height:4px;border-radius:2px;background:var(--dk-b);margin:0 auto 20px"></div>
    <div style="font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--dk-t3);margin-bottom:6px" id="jm-date"></div>
    <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--dk-t2);margin-bottom:16px" id="jm-mood"></div>
    <div style="font-size:16px;line-height:1.85;color:var(--dk-t2)" id="jm-text"></div>
  </div>
</div>

<script>
// ── ICONS ──
const ICONS=[
  {id:'mind',  l:'Mente',    s:'<circle cx="12" cy="12" r="9"/><path d="M9 9h.01M15 9h.01"/><path d="M9 13s1 2 3 2 3-2 3-2"/>'},
  {id:'book',  l:'Lectura',  s:'<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>'},
  {id:'gym',   l:'Fuerza',   s:'<path d="M6.5 6.5h11M6.5 17.5h11M3 10h3M18 10h3M3 14h3M18 14h3M6 10v4M18 10v4"/>'},
  {id:'water', l:'Agua',     s:'<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>'},
  {id:'target',l:'Meta',     s:'<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>'},
  {id:'write', l:'Escribir', s:'<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>'},
  {id:'food',  l:'Nutrición',s:'<path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2s-5 2-5 9v4z"/>'},
  {id:'sleep', l:'Sueño',    s:'<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>'},
  {id:'music', l:'Música',   s:'<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>'},
  {id:'plant', l:'Planta',   s:'<path d="M12 22V12"/><path d="M12 12C12 8 8 5 4 6c0 4 3 7 8 6"/><path d="M12 12c0-4 4-7 8-6 0 4-3 7-8 6"/>'},
  {id:'pill',  l:'Vitaminas',s:'<path d="M10.5 20.5L3.5 13.5a4.95 4.95 0 0 1 7-7l7 7a4.95 4.95 0 0 1-7 7z"/><line x1="8.5" y1="8.5" x2="15.5" y2="15.5"/>'},
  {id:'walk',  l:'Caminar',  s:'<circle cx="12" cy="5" r="1"/><path d="M9 20l1-5-2-3 3-4 2 4h3"/><path d="M6 20h4"/>'}
];
const iSVG=id=>{const x=ICONS.find(i=>i.id===id);return x?x.s:ICONS[0].s;};
document.getElementById('h-icons').innerHTML=ICONS.map((ic,i)=>
  `<button onclick="pickIcon(this,'${ic.id}')" data-icon="${ic.id}" class="ipbtn${i===4?' sel':''}">
    <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${ic.s}</svg>
    <span>${ic.l}</span>
  </button>`
).join('');

// DOW
['L','M','X','J','V','S','D'].forEach(d=>{
  const el=document.createElement('div');
  el.style.cssText='text-align:center;font-family:Barlow Condensed,sans-serif;font-weight:600;font-size:9px;letter-spacing:.14em;color:var(--dk-t3);padding:2px 0';
  el.textContent=d;document.getElementById('cal-dow').appendChild(el);
});

// ── PERSISTENCE ──
const KEY='vida_v6';
const load=()=>{try{return JSON.parse(localStorage.getItem(KEY))||{};}catch{return {};}};
const persist=d=>{try{localStorage.setItem(KEY,JSON.stringify(d));}catch{}};
let D=load();
if(!D.run)    D.run    ={sessions:[],streak:0,bestStreak:0};
if(!D.habits) D.habits ={list:[],selId:null,calMo:new Date().getMonth(),calYr:new Date().getFullYear()};
if(!D.health) D.health ={weights:[],goal:null};
if(!D.fast)   D.fast   ={active:false,startMs:null,goalH:16,history:[],streak:0};
if(!D.journal)D.journal={entries:[]};

const today=()=>new Date().toISOString().split('T')[0];
const dAgo=n=>{const d=new Date();d.setDate(d.getDate()-n);return d.toISOString().split('T')[0];};
if(!D.run.sessions.length){D.run.sessions=[{date:dAgo(18),dur:1320,km:2.4},{date:dAgo(15),dur:1680,km:3.0},{date:dAgo(12),dur:1560,km:2.8},{date:dAgo(9),dur:2040,km:3.7},{date:dAgo(7),dur:2400,km:4.3},{date:dAgo(5),dur:2760,km:4.9},{date:dAgo(3),dur:2880,km:5.2},{date:dAgo(1),dur:3120,km:5.6}];D.run.streak=5;D.run.bestStreak=7;}
