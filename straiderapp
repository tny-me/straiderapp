let musicMetadata=null;
let musicPlaying=false;
let musicInterval=null;

function initMusic(){
  // Poll Media Session metadata — works when user is playing audio in another app
  musicInterval=setInterval(pollMusic,2000);
  pollMusic();
  // Listen for visibility changes to refresh
  document.addEventListener('visibilitychange',()=>{if(!document.hidden)pollMusic();});
}

function pollMusic(){
  if('mediaSession' in navigator&&navigator.mediaSession.metadata){
    const m=navigator.mediaSession.metadata;
    const state=navigator.mediaSession.playbackState;
    musicPlaying=(state==='playing'||state==='none'); // 'none' = unknown but session exists
    const newMeta={title:m.title||'',artist:m.artist||'',album:m.album||'',artwork:m.artwork&&m.artwork.length?m.artwork[m.artwork.length-1].src:null};
    if(!musicMetadata||newMeta.title!==musicMetadata.title||newMeta.artist!==musicMetadata.artist){
      musicMetadata=newMeta;renderMusicChip();
    } else if(state!==musicMetadata._state){
      musicMetadata._state=state;renderMusicChip();
    }
  } else {
    if(musicMetadata){musicMetadata=null;renderMusicChip();}
  }
}

function renderMusicChip(){
  const el=document.getElementById('music-area');
  if(!musicMetadata||!musicMetadata.title){
    el.innerHTML=`<div class="music-chip-off" onclick="showMusicHelp()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--t3)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
      <div><div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;color:var(--t2);letter-spacing:.04em">Reproduce música para verla aquí</div><div style="font-size:11px;color:var(--t3);margin-top:2px">Spotify · Apple Music · cualquier app</div></div>
    </div>`;
    return;
  }

  const isPlaying=musicPlaying;
  const src=musicMetadata.source;

  // Detect source from artwork URL or title
  let srcColor='#888';let srcLabel='Música';
  if(musicMetadata.artwork){
    if(musicMetadata.artwork.includes('spotify'))    {srcColor='#1db954';srcLabel='Spotify';}
    else if(musicMetadata.artwork.includes('apple')) {srcColor='#fc3c44';srcLabel='Apple Music';}
    else if(musicMetadata.artwork.includes('ytimg')) {srcColor='#ff0000';srcLabel='YouTube';}
  }

  const artContent=musicMetadata.artwork
    ?`<img src="${musicMetadata.artwork}" onerror="this.style.display='none'">`
    :`<svg class="music-art-icon" viewBox="0 0 24 24"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`;

  el.innerHTML=`<div class="music-chip">
    <div class="music-art">
      ${artContent}
      ${isPlaying?`<div class="music-art-playing"><span></span><span></span><span></span></div>`:''}
    </div>
    <div class="music-info">
      <div class="music-title">${escHtml(musicMetadata.title)}</div>
      <div class="music-artist">${escHtml(musicMetadata.artist)}</div>
      <div class="music-source">
        <div class="music-source-dot" style="background:${srcColor}"></div>
        <div class="music-source-lbl">${srcLabel}</div>
      </div>
    </div>
    <div class="music-controls">
      <button class="mc-btn" onclick="mediaPrev()" title="Anterior">
        <svg viewBox="0 0 24 24"><polygon points="19 20 9 12 19 4 19 20"/><line x1="5" y1="19" x2="5" y2="5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
      </button>
      <button class="mc-btn play" onclick="mediaPlayPause()" title="${isPlaying?'Pausar':'Play'}">
        ${isPlaying
          ?`<svg viewBox="0 0 24 24"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>`
          :`<svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>`}
      </button>
      <button class="mc-btn" onclick="mediaNext()" title="Siguiente">
        <svg viewBox="0 0 24 24"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
      </button>
    </div>
  </div>`;
}

function escHtml(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

function mediaPlayPause(){
  if('mediaSession' in navigator){
    const s=navigator.mediaSession.playbackState;
    if(s==='playing'){
      navigator.mediaSession.callAction?navigator.mediaSession.callAction('pause'):document.dispatchEvent(new KeyboardEvent('keydown',{keyCode:179,bubbles:true}));
      musicPlaying=false;
    } else {
      navigator.mediaSession.callAction?navigator.mediaSession.callAction('play'):document.dispatchEvent(new KeyboardEvent('keydown',{keyCode:179,bubbles:true}));
      musicPlaying=true;
    }
    renderMusicChip();
  }
}

function mediaPrev(){
  try{if('mediaSession' in navigator&&navigator.mediaSession.callAction)navigator.mediaSession.callAction('previoustrack');}catch(e){}
  setTimeout(pollMusic,800);
}

function mediaNext(){
  try{if('mediaSession' in navigator&&navigator.mediaSession.callAction)navigator.mediaSession.callAction('nexttrack');}catch(e){}
  setTimeout(pollMusic,800);
}

