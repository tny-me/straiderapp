function renderHealth(){
  const ws=D.health.weights;
  if(ws.length){const cur=ws[ws.length-1].kg;const prev=ws.length>1?ws[ws.length-2].kg:cur;document.getElementById('w-cur').textContent=cur.toFixed(1);const diff=cur-prev;const te=document.getElementById('w-trend');if(diff<-0.05){te.textContent=`↓ ${Math.abs(diff).toFixed(1)} kg menos`;te.className='weight-trend td';}else if(diff>0.05){te.textContent=`↑ ${diff.toFixed(1)} kg más`;te.className='weight-trend tu';}else{te.textContent='→ Sin cambio';te.className='weight-trend ts';}if(D.health.goal){document.getElementById('w-goal-val').textContent=D.health.goal;const start=ws[0].kg;const rng=Math.abs(start-D.health.goal)||1;const pct=Math.min(100,Math.round(Math.abs(start-cur)/rng*100));document.getElementById('w-prog').style.width=pct+'%';document.getElementById('w-prog').style.background=cur>D.health.goal?'#ff6b6b':'#4ade80';const dd=(cur-D.health.goal).toFixed(1);const de=document.getElementById('w-diff');de.textContent=(dd>0?'+':'')+dd+' kg';de.style.cssText='font-family:Barlow Condensed,sans-serif;font-weight:700;font-size:13px;color:'+(dd>0?'#ff6b6b':'#4ade80');}
  }else{document.getElementById('w-cur').textContent='--';document.getElementById('w-trend').textContent='';}
  if(!D.health.goal)document.getElementById('w-goal-val').textContent='--';
  renderWChart();
}
function logWeight(){const v=parseFloat(document.getElementById('w-input').value);if(isNaN(v))return;D.health.weights.push({date:today(),kg:v});document.getElementById('w-input').value='';persist(D);renderHealth();}
function setWGoal(){const v=parseFloat(document.getElementById('wg-input').value);if(isNaN(v))return;D.health.goal=v;document.getElementById('wg-input').value='';persist(D);renderHealth();}
function renderWChart(){
  const ws=D.health.weights.slice(-12);const cv=document.getElementById('w-chart'),em=document.getElementById('w-empty');
  if(!ws.length){cv.style.display='none';em.style.display='block';return;}
  cv.style.display='block';em.style.display='none';
  if(wCI)wCI.destroy();
  const ctx=cv.getContext('2d');const gr=ctx.createLinearGradient(0,0,0,140);gr.addColorStop(0,'rgba(30,79,160,.16)');gr.addColorStop(1,'rgba(30,79,160,.01)');
  const ds=[{data:ws.map(w=>w.kg),borderColor:'#1e4fa0',backgroundColor:gr,tension:.4,pointRadius:3,pointBackgroundColor:'#1e4fa0',fill:true,borderWidth:2}];
  if(D.health.goal)ds.push({data:ws.map(()=>D.health.goal),borderColor:'#1a191850',borderDash:[5,4],pointRadius:0,fill:false,borderWidth:1.5});
  wCI=new Chart(cv,{type:'line',data:{labels:ws.map(w=>fmtD(w.date).split(' ').slice(0,2).join(' ')),datasets:ds},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'#1a1918',borderColor:'#2e2c28',borderWidth:1,titleColor:'#888580',bodyColor:'#f0ede8',titleFont:{family:'Barlow Condensed',weight:'600',size:11},bodyFont:{family:'Barlow Condensed',weight:'700',size:14}}},scales:{x:{ticks:{color:'#a8a49c',font:{family:'Barlow Condensed',weight:'600',size:10},maxRotation:0},grid:{color:'#e8e5e0'}},y:{ticks:{color:'#a8a49c',font:{family:'Barlow Condensed',weight:'600',size:10},callback:v=>v+'kg'},grid:{color:'#e8e5e0'}}}}});
}

// ── FAST ──
let fastInt=null;
function setFG(h){D.fast.goalH=h;persist(D);renderFast();}
function toggleFast(){
  if(!D.fast.active){D.fast.active=true;D.fast.startMs=Date.now();persist(D);fastInt=setInterval(tickFast,1000);const b=document.getElementById('fast-btn');b.textContent='Detener ayuno';b.className='btn-fast-main stop';}
  else{const hrs=(Date.now()-D.fast.startMs)/3600000;D.fast.history.unshift({date:today(),hours:+hrs.toFixed(1),goal:D.fast.goalH});if(D.fast.history.length>10)D.fast.history.pop();if(hrs>=D.fast.goalH)D.fast.streak++;D.fast.active=false;D.fast.startMs=null;persist(D);clearInterval(fastInt);const b=document.getElementById('fast-btn');b.textContent='Iniciar ayuno';b.className='btn-fast-main start';['fast-timer','fast-pct','fast-el-v','fast-sub','fast-start-lbl'].forEach((id,i)=>{document.getElementById(id).textContent=['00:00','0%','0.0','en ayuno',''][i];});document.getElementById('fast-ring').setAttribute('stroke-dashoffset','590.6');renderFast();}
}
function tickFast(){if(!D.fast.startMs)return;const el=Math.floor((Date.now()-D.fast.startMs)/1000);const gs=D.fast.goalH*3600;const p=Math.min(1,el/gs);document.getElementById('fast-timer').textContent=fmtSh(el);document.getElementById('fast-el-v').textContent=(el/3600).toFixed(1);document.getElementById('fast-pct').textContent=Math.round(p*100)+'%';document.getElementById('fast-ring').setAttribute('stroke-dashoffset',590.6*(1-p));if(el>=gs)document.getElementById('fast-sub').textContent='Meta alcanzada';}
function renderFast(){
  document.getElementById('fast-goal-v').textContent=D.fast.goalH;document.getElementById('fast-stk-v').textContent=D.fast.streak;
  [12,14,16,18,20].forEach(h=>{const b=document.getElementById('fg-'+h);if(!b)return;b.className='proto-btn'+(D.fast.goalH===h?' on':'');});
  if(D.fast.active&&D.fast.startMs){const st=new Date(D.fast.startMs);document.getElementById('fast-start-lbl').textContent=`Iniciado a las ${st.getHours()}:${pad(st.getMinutes())}`;const b=document.getElementById('fast-btn');b.textContent='Detener ayuno';b.className='btn-fast-main stop';if(!fastInt)fastInt=setInterval(tickFast,1000);tickFast();}
  const chk='<svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>';
  const xic='<svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
  document.getElementById('fast-hist').innerHTML=D.fast.history.slice(0,5).map(f=>{const done=f.hours>=f.goal;return `<div class="fhi"><div><div class="fhi-date">${fmtD(f.date)}</div><div class="fhi-sub">${f.hours}h de ${f.goal}h meta</div></div><div class="fhi-st" style="color:${done?'#4ade80':'#fb923c'}">${done?chk:xic} ${done?'Completo':'Parcial'}</div></div>`;}).join('')||'<div class="empty-dk">Sin registros aún</div>';
}

// ── JOURNAL ──
function renderJournal(){
  const now=new Date();document.getElementById('j-today-lbl').textContent=`${DAYS[now.getDay()]} ${now.getDate()} ${MONTHS[now.getMonth()]} ${now.getFullYear()}`;
  document.getElementById('j-entries').innerHTML=D.journal.entries.map(e=>`<div class="je-card" onclick="viewJ('${e.id}')"><div class="je-date">${fmtD(e.date)}</div>${e.mood?`<div class="je-mood">${e.mood}</div>`:''}  <div class="je-preview">${e.text}</div></div>`).join('')||'<div class="empty-state">Escribe tu primera entrada</div>';
}
document.getElementById('j-input').addEventListener('input',function(){document.getElementById('j-wc').textContent=this.value.trim().split(/\s+/).filter(Boolean).length+' palabras';});
function saveJournal(){const text=document.getElementById('j-input').value.trim();if(!text)return;const mood=document.getElementById('j-mood').value;D.journal.entries.unshift({id:'j'+Date.now(),date:today(),mood,text});document.getElementById('j-input').value='';document.getElementById('j-mood').value='';document.getElementById('j-wc').textContent='0 palabras';persist(D);renderJournal();}
function viewJ(id){const e=D.journal.entries.find(x=>x.id===id);if(!e)return;document.getElementById('jm-date').textContent=fmtD(e.date);document.getElementById('jm-mood').textContent=e.mood||'';document.getElementById('jm-text').textContent=e.text;openModal('j-modal');}

// ── BOOT ──
renderRun();
initMusic();
if(D.fast.active&&D.fast.startMs){fastInt=setInterval(tickFast,1000);tickFast();}
</script>
</body>
